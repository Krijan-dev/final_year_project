# Paste your Atlas connection string from: Atlas → Connect → Drivers
# Put the real value only in server/.env (gitignored) — not in docs or git.
MONGODB_URI=

PORT=3000

# Admin dashboard (website login)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Email verification (sign-up). Use Gmail App Password, SendGrid SMTP, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Life Pattern Tracker <noreply@yourdomain.com>

# Local dev without SMTP: codes print in Render/server logs. Set to 1 to return code in API (dev only).
EMAIL_DEV_EXPOSE_CODE=1
