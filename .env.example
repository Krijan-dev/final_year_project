# Copy this file to ".env" in the project root and set your key.
# The real ".env" file is gitignored — never commit it.
#
# Flutter .env rules: no spaces around `=`, no quotes needed, UTF-8 (no BOM).
# Good:  GEMINI_API_KEY=your_key_here
# Bad:   GEMINI_API_KEY= your_key_here

GEMINI_API_KEY=

# Optional: sync usage to MongoDB API (see docs/MONGODB.md). Android emulator → host:
# API_BASE_URL=http://10.0.2.2:3000
API_BASE_URL=
