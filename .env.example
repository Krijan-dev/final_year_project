# Copy to ".env" in the project root. Never commit .env.
#
# Flutter: .\run_dev.ps1  (uses flutter.env — only GEMINI + API_BASE_URL; never pass full .env)
# Sync to website + server: .\scripts\sync-env.ps1

# Google Gemini (app AI features)
GEMINI_API_KEY=

# REST API (Flutter app + website). Examples:
#   Local PC:     http://127.0.0.1:3000
#   Emulator:     http://10.0.2.2:3000
#   LAN phone:    http://YOUR_PC_IP:3000
#   Render prod:  https://your-service.onrender.com
API_BASE_URL=

# MongoDB Atlas (API on Render / local server). Sync copies to server/.env
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority

# Admin website login (sync copies to server/.env — set same values on Render)
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=your-secure-password

# Sign-up codes sent FROM your own inbox (Gmail App Password — see docs/EMAIL_VERIFICATION.md)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=16char-app-password-from-google
# SMTP_FROM="Life Pattern Tracker <your.email@gmail.com>"
